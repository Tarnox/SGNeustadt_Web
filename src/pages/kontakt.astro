---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Kontakt – SG Neustadt";
const description = "Schreib uns eine Nachricht. Wir melden uns zeitnah zurück.";
---
<BaseLayout title="Kontakt – SG Neustadt" description="Kontaktformular der SG Neustadt.">
  <div class="page">
    <header class="page-head">
      <div class="lead">
        <h1 class="m0">Kontakt</h1>
        <p class="m0">Schreib uns eine Nachricht. Wir melden uns zeitnah zurück.</p>
      </div>
      <span class="badge">🛡 Anti-Spam aktiv</span>
    </header>

    <section class="card card-pad" style="max-width: 720px;">
      <form id="contactForm" class="form">
        <div class="field">
          <label for="name"><strong>Name</strong></label>
          <input id="name" class="input" name="name" required minlength="2" />
        </div>

        <div class="field">
          <label for="email"><strong>E-Mail</strong></label>
          <input id="email" class="input" name="email" type="email" required />
        </div>

        <div class="field">
          <label for="message"><strong>Nachricht</strong></label>
          <textarea id="message" name="message" required minlength="10" rows="6"></textarea>
        </div>

        <!-- Honeypot -->
        <div class="hp" style="position:absolute;left:-9999px;top:-9999px;">
          <label>Website <input name="website" autocomplete="off" /></label>
        </div>

        <input type="hidden" name="startedAt" id="startedAt" />
        <input type="hidden" name="powNonce" id="powNonce" />
        <input type="hidden" name="powHash" id="powHash" />

        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
          <button class="btn primary" type="submit">Absenden</button>
          <span id="status" class="status" role="status" aria-live="polite"></span>
        </div>
      </form>
    </section>
  </div>

  <!-- Dein Script bleibt wie es ist (PoW etc.) -->
</BaseLayout>
