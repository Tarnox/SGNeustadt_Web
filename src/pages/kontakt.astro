---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Kontakt">
  <h2>Kontakt</h2>

  <p>Schreib uns eine Nachricht. Wir melden uns zeitnah zurück.</p>

  <form id="contactForm" class="form">
    <label>
      Name
      <input name="name" required minlength="2" />
    </label>

    <label>
      E-Mail
      <input name="email" type="email" required />
    </label>

    <label>
      Nachricht
      <textarea name="message" required minlength="10" rows="6"></textarea>
    </label>

    <!-- Honeypot (Spam-Schutz): muss leer bleiben -->
    <div class="hp">
      <label>
        Website
        <input name="website" autocomplete="off" />
      </label>
    </div>

<input type="hidden" name="startedAt" id="startedAt" />
<input type="hidden" name="powNonce" id="powNonce" />
<input type="hidden" name="powHash" id="powHash" />

    <button type="submit">Absenden</button>

    <p id="status" class="status" role="status" aria-live="polite"></p>
  </form>

<script>
  const form = document.getElementById("contactForm");
  const statusEl = document.getElementById("status");

  const startedAtEl = document.getElementById("startedAt");
  const powNonceEl = document.getElementById("powNonce");
  const powHashEl = document.getElementById("powHash");

  // Set start time on load
  startedAtEl.value = String(Date.now());

  function toHex(buffer) {
    return Array.from(new Uint8Array(buffer))
      .map((b) => b.toString(16).padStart(2, "0"))
      .join("");
  }

  async function sha256Hex(str) {
    const enc = new TextEncoder();
    const buf = await crypto.subtle.digest("SHA-256", enc.encode(str));
    return toHex(buf);
  }

  async function computePow({ name, email, message, startedAt }) {
    const prefix = "0000"; // must match server
    let nonce = 0;

    while (true) {
      const base = `${name}|${email}|${message}|${startedAt}|${nonce}`;
      const hash = await sha256Hex(base);

      if (hash.startsWith(prefix)) {
        return { powNonce: String(nonce), powHash: hash };
      }

      nonce++;
      if (nonce % 200 === 0) {
        await new Promise((r) => setTimeout(r, 0));
      }
    }
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    statusEl.textContent = "Berechne Anti-Spam…";

    try {
      const fd = new FormData(form);
      const name = String(fd.get("name") || "").trim();
      const email = String(fd.get("email") || "").trim();
      const message = String(fd.get("message") || "").trim();
      const startedAt = String(fd.get("startedAt") || "").trim();

      const { powNonce, powHash } = await computePow({ name, email, message, startedAt });
      powNonceEl.value = powNonce;
      powHashEl.value = powHash;

      statusEl.textContent = "Sende…";

      const payload = Object.fromEntries(new FormData(form).entries());

      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      const text = await res.text();
      let dataObj = {};
      try {
        dataObj = JSON.parse(text);
      } catch {
        // ignore
      }

      if (!res.ok || !dataObj.ok) {
        statusEl.textContent = dataObj.error || text || "Fehler beim Senden.";
        return;
      }

      form.reset();
      startedAtEl.value = String(Date.now());
      statusEl.textContent = "Danke! Nachricht wurde gesendet.";
    } catch (err) {
      statusEl.textContent = "Fehler. Bitte später erneut versuchen.";
    }
  });
</script>

  <style>
    .form { max-width: 620px; display: grid; gap: 12px; }
    label { display: grid; gap: 6px; }
    input, textarea {
      padding: 10px 12px;
      border: 1px solid #d1d5db;
      border-radius: 10px;
      font: inherit;
    }
    button {
      padding: 10px 14px;
      border: 0;
      border-radius: 10px;
      cursor: pointer;
    }
    .status { margin-top: 6px; }

    /* honeypot verstecken */
    .hp { position: absolute; left: -9999px; top: -9999px; }
  </style>
</BaseLayout>
