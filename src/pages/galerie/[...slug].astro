---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const galleries = await getCollection("galleries");
  return galleries.map((g) => ({
    params: { slug: g.slug },
    props: { gallery: g },
  }));
}

const { gallery } = Astro.props;
const { Content } = await render(gallery);
const title = `${gallery.data.title} – SG Neustadt`;
const description =
  gallery.data.description ??
  `Fotogalerie: ${gallery.data.title} (${gallery.data.date.toLocaleDateString("de-DE")}).`;

let galleries = [];
try { galleries = await getCollection("galleries"); } catch { galleries = []; }
---

<BaseLayout title={title} description={description}>
  <div class="page">
    <header class="page-head">
      <div class="lead">
        <a class="btn" href="/galerie/">← Zurück zur Galerie</a>
        <h1 class="mt12">{gallery.data.title}</h1>
        <p class="m0">{gallery.data.date.toLocaleDateString("de-DE")}</p>
      </div>
      <span class="badge">📷 {gallery.data.images.length} Bilder</span>
    </header>

    <!-- Masonry Grid (dein Block bleibt) -->
    <div class="gallery-grid" aria-label="Bildergalerie">
      {gallery.data.images.map((img, i) => (
        <figure class="gallery-item">
          <img
            src={img.src}
            alt={img.alt ?? ""}
            data-index={i}
            class="gallery-image"
            loading={i < 2 ? "eager" : "lazy"}
            decoding="async"
            fetchpriority={i === 0 ? "high" : "auto"}
          />
          {img.alt && <figcaption>{img.alt}</figcaption>}
        </figure>
      ))}
    </div>

    <!-- Lightbox (dein Block bleibt) -->
    <!-- ... -->

    <section class="card card-pad mt20">
      <Content />
    </section>
  </div>
</BaseLayout>
