---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const galleries = (await getCollection("galleries"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Galerie">
  <h2>Galerie</h2>

  {galleries.length === 0 ? <p>Noch keine Galerien.</p> : (
    <ul style="list-style:none;padding:0;display:grid;gap:16px;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));">
      {galleries.map(g => (
        <li style="background:#fff;border-radius:14px;padding:14px;box-shadow:0 6px 18px rgba(0,0,0,.08);">
          <a href={`/galerie/${g.slug}/`} style="text-decoration:none;color:inherit;">
            {g.data.cover && (
              <img src={g.data.cover} alt="" style="width:100%;height:160px;object-fit:cover;border-radius:12px;" />
            )}
            <h3 style="margin:12px 0 4px;">{g.data.title}</h3>
            <div style="opacity:.8;">
              {g.data.date.toLocaleDateString("de-DE")} • {g.data.images?.length ?? 0} Bilder
            </div>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
