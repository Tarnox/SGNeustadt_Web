---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const events = await getCollection("events");
events.sort((a, b) => a.data.start.getTime() - b.data.start.getTime());

const now = new Date();
const nextEvent = events.find((e) => e.data.start >= now) ?? null;

const news = await getCollection("news");
news.sort((a, b) => (b.data.date?.getTime?.() ?? 0) - (a.data.date?.getTime?.() ?? 0));
const latestNews = news.slice(0, 5);
---

<BaseLayout
  title="SG Neustadt – Schützengesellschaft"
  description="Schützenverein SG Neustadt – Training, Termine, News, Galerie und Downloads."
>
  <!-- HERO -->
  <section class="hero card">
    <div class="hero-text">
      <div class="chip green">🏹 Training • Gemeinschaft • Tradition</div>
      <h1>Schützengesellschaft Neustadt</h1>
      <p>
        Willkommen bei der SG Neustadt. Hier findest du aktuelle News, anstehende Termine,
        Bilder aus dem Vereinsleben und wichtige Dokumente als Download.
      </p>

      <div class="hero-actions">
        <a class="btn primary" href="/termine/">Nächste Termine</a>
        <a class="btn" href="/news/">Neueste News</a>
        <a class="btn accent" href="/kontakt/">Kontakt</a>
      </div>
    </div>

    <div class="hero-media" aria-hidden="true">
      <img src="/hero.jpg" alt="" loading="eager" />
      <div class="hero-overlay"></div>

      <!-- Watermark Logo -->
      <img class="hero-logo" src="/logo.png" alt="" loading="eager" />
    </div>
  </section>

  <!-- QUICK TILES -->
  <section class="tiles">
    <a class="tile card" href="/news/">
      <span class="icon">📰</span>
      <div>
        <strong>News</strong>
        <div class="muted">Aktuelles aus dem Verein</div>
      </div>
    </a>

    <a class="tile card" href="/termine/">
      <span class="icon">📅</span>
      <div>
        <strong>Termine</strong>
        <div class="muted">Wettkämpfe & Veranstaltungen</div>
      </div>
    </a>

    <a class="tile card" href="/galerie/">
      <span class="icon">🖼️</span>
      <div>
        <strong>Galerie</strong>
        <div class="muted">Bilder & Eindrücke</div>
      </div>
    </a>

    <a class="tile card" href="/downloads/">
      <span class="icon">📄</span>
      <div>
        <strong>Downloads</strong>
        <div class="muted">Dokumente & PDFs</div>
      </div>
    </a>
  </section>

  <!-- HIGHLIGHTS -->
  <section class="grid">
    <div class="card pad">
      <div class="row">
        <h2>Nächster Termin</h2>
        <span class="chip gold">📌 Highlight</span>
      </div>

      {!nextEvent ? (
        <p class="muted">Aktuell sind keine kommenden Termine eingetragen.</p>
      ) : (
        <div class="event">
          <div class="event-title">{nextEvent.data.title}</div>
          <div class="muted">
            {nextEvent.data.start.toLocaleString("de-DE")}
            {nextEvent.data.location ? ` • ${nextEvent.data.location}` : ""}
          </div>
          <div style="margin-top:12px">
            <a class="btn primary" href="/termine/">Alle Termine</a>
          </div>
        </div>
      )}
    </div>

    <div class="card pad">
      <div class="row">
        <h2>Neueste News</h2>
        <span class="chip red">🆕 Updates</span>
      </div>

      {latestNews.length === 0 ? (
        <p class="muted">Noch keine News vorhanden.</p>
      ) : (
        <ul class="news-list">
          {latestNews.map((post) => (
            <li>
              <a href={`/news/${post.slug}/`} class="news-link">
                <span class="news-title">{post.data.title}</span>
                {post.data.date && (
                  <span class="news-date">
                    {post.data.date.toLocaleDateString("de-DE")}
                  </span>
                )}
              </a>
            </li>
          ))}
        </ul>
      )}

      <div style="margin-top:12px">
        <a class="btn" href="/news/">Alle News</a>
      </div>
    </div>
  </section>

  <style>
    .hero{display:grid; gap:16px; padding:18px;}
    @media(min-width:920px){.hero{grid-template-columns: 1.05fr .95fr; align-items:stretch; padding:22px;}}
    .hero-text p{color:var(--muted); max-width:62ch; margin-top:8px;}
    .hero-actions{display:flex; gap:10px; flex-wrap:wrap; margin-top:12px;}

    .hero-media{position:relative; border-radius:16px; border:1px solid var(--border); overflow:hidden; min-height:240px;}
    .hero-media img:first-child{width:100%; height:100%; object-fit:cover; display:block; filter:saturate(1.05) contrast(1.06);}
    .hero-overlay{
      position:absolute; inset:0; pointer-events:none;
      background:
        radial-gradient(900px 400px at 20% 25%, rgba(31,74,49,.45), transparent 60%),
        radial-gradient(900px 400px at 85% 20%, rgba(143,26,41,.35), transparent 55%),
        linear-gradient(180deg, rgba(11,26,18,.25), rgba(11,26,18,.05));
    }
    .hero-logo{
      position:absolute;
      right:14px;
      bottom:14px;
      width:90px;
      height:90px;
      object-fit:contain;
      opacity:.92;
      filter: drop-shadow(0 14px 30px rgba(2,6,23,.25));
      border-radius: 18px;
      padding:10px;
      background: rgba(255,255,255,.78);
      border:1px solid var(--border);
      backdrop-filter: blur(10px);
    }

    .tiles{display:grid; gap:12px; margin:14px 0 18px;}
    @media(min-width:860px){.tiles{grid-template-columns:repeat(4,minmax(0,1fr));}}
    .tile{padding:14px; display:flex; gap:12px; align-items:center; text-decoration:none; color:inherit;}
    .tile .icon{font-size:22px}
    .tile .muted{opacity:.78; font-size:.92rem; margin-top:2px}

    .grid{display:grid; gap:14px;}
    @media(min-width:920px){.grid{grid-template-columns: 1.2fr .8fr;}}
    .pad{padding:18px;}
    .row{display:flex; align-items:center; justify-content:space-between; gap:10px;}
    h1{margin:10px 0 0}
    h2{margin:0}
    .muted{color:var(--muted)}
    .event{margin-top:10px}
    .event-title{font-weight:900; font-size:1.05rem; margin-bottom:4px}

    .news-list{list-style:none; padding:0; margin:10px 0 0; display:grid; gap:8px;}
    .news-link{
      display:flex; justify-content:space-between; gap:10px;
      text-decoration:none; color:inherit;
      padding:10px 12px;
      border-radius:12px;
      border:1px solid var(--border);
      background: rgba(255,255,255,.55);
    }
    .news-link:hover{border-color: color-mix(in oklab, var(--accent-500) 30%, var(--border));}
    .news-title{font-weight:900}
    .news-date{color:var(--muted); font-weight:800; font-size:.92rem; white-space:nowrap}
  </style>
</BaseLayout>
