---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

let events = [];
let news = [];

try { events = await getCollection("events"); } catch { events = []; }
try { news = await getCollection("news"); } catch { news = []; }

// Nächster Termin
events.sort((a,b) => a.data.start.getTime() - b.data.start.getTime());
const now = new Date();
const nextEvent = events.find(e => e.data.start >= now) ?? null;

// Neueste News (max 3)
news.sort((a,b) => b.data.date.getTime() - a.data.date.getTime());
const latestNews = news.slice(0, 3);
---

<BaseLayout title="Start">
  <h2>Willkommen bei der Schützengesellschaft Neustadt</h2>

<section class="hero card">
  <div class="hero-text">
    <div class="chip green">🏹 Training • Gemeinschaft • Tradition</div>
    <h1>Willkommen bei der SG Neustadt</h1>
    <p>
      Infos zu Training, Terminen, News, Galerie und Downloads – alles einfach gepflegt über unser Vereins-CMS.
    </p>
    <div class="hero-actions">
      <a class="btn primary" href="/termine/">Nächste Termine</a>
      <a class="btn" href="/kontakt/">Kontakt</a>
    </div>
  </div>

  <div class="hero-media" aria-hidden="true">
    <img src="/hero.jpg" alt="" loading="eager" />
  </div>
</section>

<section class="tiles">
  <a class="tile card" href="/news/"><span>📰</span><div><strong>News</strong><div class="muted">Aktuelles aus dem Verein</div></div></a>
  <a class="tile card" href="/termine/"><span>📅</span><div><strong>Termine</strong><div class="muted">Wettkämpfe & Veranstaltungen</div></div></a>
  <a class="tile card" href="/galerie/"><span>🖼️</span><div><strong>Galerie</strong><div class="muted">Bilder & Eindrücke</div></div></a>
  <a class="tile card" href="/downloads/"><span>📄</span><div><strong>Downloads</strong><div class="muted">PDFs & Dokumente</div></div></a>
</section>

<section class="home-grid">
  <div class="box">
    <h2>Nächster Termin</h2>
    {nextEvent ? (
      <div>
        <div class="big">{nextEvent.data.title}</div>
        <div class="muted">
          {nextEvent.data.start.toLocaleString("de-DE")}
          {nextEvent.data.location && <> · {nextEvent.data.location}</>}
        </div>
        <p style="margin-top:10px;">
          <a class="btn" href="/termine/">Alle Termine</a>
        </p>
      </div>
    ) : (
      <p class="muted">Aktuell sind keine kommenden Termine eingetragen.</p>
    )}
  </div>

  <div class="box">
    <h2>Neueste News</h2>
    {latestNews.length === 0 ? (
      <p class="muted">Noch keine News vorhanden.</p>
    ) : (
      <ul class="list">
        {latestNews.map(p => (
          <li>
            <a href={`/news/${p.slug}/`}>{p.data.title}</a>
            <div class="muted">{p.data.date.toLocaleDateString("de-DE")}</div>
          </li>
        ))}
      </ul>
    )}
    <p style="margin-top:10px;">
      <a class="btn" href="/news/">Alle News</a>
    </p>
  </div>
</section>

<style>

  .hero{
    display:grid;
    gap:16px;
    padding:18px;
    overflow:hidden;
    position:relative;
  }
  @media(min-width:920px){
    .hero{grid-template-columns: 1.1fr .9fr; align-items:center; padding:22px;}
  }
  .hero-text p{color:var(--muted); max-width:58ch}
  .hero-actions{display:flex; gap:10px; flex-wrap:wrap; margin-top:10px}
  .hero-media{
    border-radius:16px;
    border:1px solid var(--border);
    background: rgba(2,6,23,.03);
    overflow:hidden;
    min-height:220px;
  }
  .hero-media img{
    width:100%; height:100%;
    object-fit:cover;
    display:block;
    transform: scale(1.02);
  }

<style>
  .tiles{display:grid;gap:12px;margin:14px 0}
  @media(min-width:860px){.tiles{grid-template-columns:repeat(4,minmax(0,1fr));}}
  .tile{padding:14px;display:flex;gap:12px;align-items:center;text-decoration:none}
  .tile span{font-size:22px}
  .tile .muted{opacity:.75;font-size:.92rem;margin-top:2px}
</style>

  .home-grid{display:grid;gap:12px;grid-template-columns:repeat(1,minmax(0,1fr));margin:18px 0 6px;}
  @media(min-width:860px){.home-grid{grid-template-columns:repeat(2,minmax(0,1fr));}}
  .box{border:1px solid rgba(0,0,0,.08);border-radius:16px;padding:16px;background:#fff}
  .big{font-weight:800;font-size:1.1rem;margin-top:6px}
  .muted{opacity:.75}
  .list{list-style:none;padding:0;margin:10px 0 0;display:grid;gap:10px}
  .btn{display:inline-block;padding:8px 10px;border-radius:12px;border:1px solid rgba(0,0,0,.10);background:rgba(0,0,0,.03);text-decoration:none;color:inherit;font-weight:600}
</style>

</BaseLayout>
