---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const news = (await getCollection("news"))
  .sort((a, b) => new Date(b.data.date) - new Date(a.data.date))
  .slice(0, 3);

const events = await getCollection("events");

const upcoming = events
  .filter(e => new Date(e.data.start) >= new Date())
  .sort((a, b) => new Date(a.data.start) - new Date(b.data.start))
  .slice(0, 5);
---

<BaseLayout title="Start">
  <h2>Willkommen bei der Schützengesellschaft Neustadt</h2>

  <h3>Nächste Termine</h3>

  {upcoming.length === 0 && <p>Keine anstehenden Termine.</p>}

  <ul>
    {upcoming.map(event => (
      <li>
        <strong>{event.data.title}</strong><br />
        {new Date(event.data.start).toLocaleString("de-DE")}
        {event.data.location && <> – {event.data.location}</>}
      </li>
      <p><a href="/termine">Alle Termine ansehen →</a></p>
    ))}
  </ul>
<h3>Neuigkeiten</h3>
{news.length === 0 ? <p>Noch keine News.</p> : (
  <ul>
    {news.map(p => (
      <li>
        <a href={`/news/${p.slug}/`}><strong>{p.data.title}</strong></a><br />
        {new Date(p.data.date).toLocaleDateString("de-DE")}
      </li>
    ))}
  </ul>
)}
<p><a href="/news">Alle News ansehen →</a></p>

</BaseLayout>
