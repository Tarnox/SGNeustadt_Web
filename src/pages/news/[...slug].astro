---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("news");
  return posts.map((p) => ({
    params: { slug: p.slug },
    props: { post: p },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const title = `${post.data.title} – SG Neustadt`;
const description =
  post.data.description ??
  post.data.excerpt ??
  "Neuigkeiten vom Schützenverein SG Neustadt.";
---

<BaseLayout title={post.data.title} description={description}>
  <p><a href="/news">← Zurück zu News</a></p>
  <h2>{post.data.title}</h2>
  <p>{post.data.date.toLocaleDateString("de-DE")}</p>

  {post.data.cover && (
    <p><img src={post.data.cover} alt="" style="max-width:100%;border-radius:12px;" /></p>
  )}

  <Content />
</BaseLayout>
