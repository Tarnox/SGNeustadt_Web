---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("news");
  return entries.map((e) => ({ params: { slug: e.slug }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const title = `${entry.data.title} – SG Neustadt`;
const description =
  entry.data.description ??
  entry.data.excerpt ??
  "Neuigkeiten vom Schützenverein SG Neustadt.";
---

<BaseLayout title={post.data.title}>
  <p><a href="/news">← Zurück zu News</a></p>
  <h2>{post.data.title}</h2>
  <p>{post.data.date.toLocaleDateString("de-DE")}</p>

  {post.data.cover && (
    <p><img src={post.data.cover} alt="" style="max-width:100%;border-radius:12px;" /></p>
  )}

  <Content />
</BaseLayout>
