---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("news");
  return posts.map((p) => ({
    params: { slug: p.slug },
    props: { post: p },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const title = `${post.data.title} – SG Neustadt`;
const description =
  post.data.description ??
  post.data.excerpt ??
  "Neuigkeiten vom Schützenverein SG Neustadt.";
---

<BaseLayout title={title} description={description}>
  <div class="page">
    <header class="page-head">
      <div class="lead">
        <a class="btn" href="/news/">← Zurück</a>
        <h1 class="mt12">{post.data.title}</h1>
        <p class="m0">{post.data.date.toLocaleDateString("de-DE")}</p>
      </div>
      <span class="badge">SG Neustadt</span>
    </header>

    {post.data.cover && (
      <section class="card" style="overflow:hidden; border-radius: var(--r-lg);">
        <img src={post.data.cover} alt="" loading="lazy" style="display:block;width:100%;height:auto;" />
      </section>
    )}

    <section class="card card-pad mt16">
      <Content />
    </section>
  </div>
</BaseLayout>
