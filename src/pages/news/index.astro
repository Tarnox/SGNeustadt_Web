---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("news");
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const title = "News – SG Neustadt";
const description = "Aktuelle Neuigkeiten, Berichte und Informationen vom Schützenverein SG Neustadt.";
---

<BaseLayout title="News">
  <h2>News</h2>

  {posts.length === 0 ? <p>Noch keine Beiträge.</p> : (
    <ul>
      {posts.map(p => (
        <li>
          <a href={`/news/${p.slug}/`}><strong>{p.data.title}</strong></a><br />
          {p.data.date.toLocaleDateString("de-DE")}
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
