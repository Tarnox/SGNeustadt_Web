---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const title = "Termine – SG Neustadt";
const description = "Alle Termine und Veranstaltungen des Schützenvereins SG Neustadt.";

const events = await getCollection("events");
events.sort((a, b) => a.data.start.getTime() - b.data.start.getTime());

const now = new Date();
const upcoming = events.filter((e) => e.data.start >= now);
const past = events
  .filter((e) => e.data.start < now)
  .sort((a, b) => b.data.start.getTime() - a.data.start.getTime());

// JSON-LD (Event SEO)
const origin = Astro.url.origin;

const eventJsonLd = upcoming.map((e) => {
  const start = e.data.start.toISOString();
  const end = e.data.end ? e.data.end.toISOString() : undefined;

  return {
    "@context": "https://schema.org",
    "@type": "Event",
    name: e.data.title,
    startDate: start,
    ...(end ? { endDate: end } : {}),
    eventStatus: "https://schema.org/EventScheduled",
    eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
    url: `${origin}/termine/`,
    ...(e.data.location ? { location: { "@type": "Place", name: e.data.location } } : {}),
  };
});

const eventsListJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Termine – SG Neustadt",
  itemListElement: eventJsonLd.map((ev, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: ev,
  })),
};

function fmtDate(d) {
  return new Date(d).toLocaleString("de-DE", { dateStyle: "medium", timeStyle: "short" });
}
---
<BaseLayout title={title} description={description} jsonLd={[eventsListJsonLd]}>
  <div class="page">
    <header class="page-head">
      <div class="lead">
        <h1 class="m0">Termine</h1>
        <p class="m0">Alle Termine und Veranstaltungen der SG Neustadt.</p>
      </div>
      <a class="btn primary" href="/kontakt/">Frage stellen</a>
    </header>

    <div class="split">
      <section class="card card-pad">
        <h2 class="m0">Bevorstehend</h2>
        <p class="mt8">Die nächsten Veranstaltungen und Trainings.</p>

        {upcoming.length === 0 ? (
          <div class="row mt12">
            <div class="meta">
              <strong>Keine anstehenden Termine</strong>
              <div class="sub">Sobald neue Termine eingetragen sind, erscheinen sie hier.</div>
            </div>
          </div>
        ) : (
          <div class="mt12" style="display:grid; gap:10px;">
            {upcoming.map((event) => (
              <div class="row">
                <div class="meta">
                  <strong>{event.data.title}</strong>
                  <div class="sub">
                    {new Date(event.data.start).toLocaleString("de-DE")}
                    {event.data.location && <> · {event.data.location}</>}
                  </div>
                </div>
                <div class="right">
                  <span class="badge">📅 Termin</span>
                </div>
              </div>
            ))}
          </div>
        )}
      </section>

      <aside class="card card-pad">
        <h2 class="m0">Vergangen</h2>
        <p class="mt8">Letzte Veranstaltungen (max. 20).</p>

        {past.length === 0 ? (
          <div class="row mt12">
            <div class="meta">
              <strong>Noch keine vergangenen Termine</strong>
              <div class="sub">Sobald Termine stattgefunden haben, werden sie hier gelistet.</div>
            </div>
          </div>
        ) : (
          <div class="mt12" style="display:grid; gap:10px;">
            {past.slice(0, 20).map((event) => (
              <div class="row">
                <div class="meta">
                  <strong>{event.data.title}</strong>
                  <div class="sub">
                    {new Date(event.data.start).toLocaleString("de-DE")}
                    {event.data.location && <> · {event.data.location}</>}
                  </div>
                </div>
                <div class="right">
                  <span class="badge">🕘 Archiv</span>
                </div>
              </div>
            ))}
          </div>
        )}
      </aside>
    </div>
  </div>
</BaseLayout>
