---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("downloads");

const grouped = new Map();

for (const e of entries) {
  const cat = e.data.category || "Allgemein";
  if (!grouped.has(cat)) grouped.set(cat, []);
  grouped.get(cat).push(e);
}

const cats = Array.from(grouped.keys()).sort();
---

<BaseLayout title="Downloads – SG Neustadt">
  <div class="page">

    <header class="page-head">
      <div class="lead">
        <h1 class="m0">Downloads</h1>
        <p class="m0">
          Wichtige Dokumente (PDF) rund um den Verein – sauber nach Kategorien sortiert.
        </p>
      </div>

      <a class="btn" href="/kontakt/">Fehlt ein Dokument?</a>
    </header>

    {entries.length === 0 ? (
      <section class="card card-pad">
        <p class="m0">Noch keine Downloads vorhanden.</p>
      </section>
    ) : (
      cats.map((cat) => (
        <section class="section">
          <h2>{cat}</h2>

          <div class="grid">
            {grouped.get(cat).map((d) => (
              <a class="card card-pad row" href={d.data.file} target="_blank">
                <div class="meta">
                  <strong>{d.data.title}</strong>

                  {d.data.description && (
                    <div class="sub">{d.data.description}</div>
                  )}
                </div>

                <div class="right">
                  <span class="badge">PDF</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))
    )}
  </div>
</BaseLayout>
