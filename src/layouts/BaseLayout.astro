---
const {
  title = "SG Neustadt",
  description = "Schützenverein SG Neustadt – Informationen zu Training, Veranstaltungen und Vereinsleben.",
  jsonLd = null,
} = Astro.props;

const origin = Astro.url.origin; // z.B. https://beta.sgneustadt.de oder https://sgneustadt.de
const canonical = `${origin}${Astro.url.pathname}`;
const ogImage = `${origin}/og-image.jpg`;

// Vereinsdaten (bitte später ggf. anpassen)
const ORG_NAME = "Schützenverein SG Neustadt";
const ORG_URL = origin;
const ORG_LOGO = `${origin}/favicon.svg`;

// JSON-LD: kann Objekt oder Array sein
---
const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "SportsOrganization",
  "name": ORG_NAME,
  "url": ORG_URL,
  "logo": ORG_LOGO,
  // optional, wenn ihr es öffentlich wollt:
  // "email": "beta@sgneustadt.de",
  // "telephone": "+49 ...",
  // "address": { "@type": "PostalAddress", "addressLocality": "Neustadt", "addressCountry": "DE" }
};
const mergedJsonLdArray = [orgJsonLd, ...jsonLdArray];
---
---

<!DOCTYPE html>
<html lang="de">
  <head>

<title>{title}</title>

<meta name="description" content={description} />

<link rel="canonical" href={`https://sgneustadt.de${Astro.url.pathname}`} />

  <!-- Open Graph (Facebook / WhatsApp / Discord Vorschau) -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={`https://sgneustadt.de${Astro.url.pathname}`} />
  <meta property="og:image" content="https://beta.sgneustadt.de/og-image.jpg" />

  <!-- Twitter Preview -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://beta.sgneustadt.de/og-image.jpg" />

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

{jsonLdArray.map((obj) => (
  <script type="application/ld+json" set:html={JSON.stringify(obj)} />
))}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SportsOrganization",
  "name": "Schützenverein SG Neustadt",
  "url": "https://sgneustadt.de",
  "logo": "https://sgneustadt.de/favicon.svg",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Neustadt",
    "addressCountry": "DE"
  }
}
</script>

    <style>
      body { font-family: system-ui, sans-serif; margin: 0; background: #f8f9fa; }
      header { background: #1f2937; color: white; padding: 1rem; }
      nav a { color: white; margin-right: 1rem; text-decoration: none; }
      nav a:hover { text-decoration: underline; }
      main { max-width: 1000px; margin: 2rem auto; padding: 1rem; background: white; }
      footer { background: #111827; color: #ccc; padding: 2rem; text-align: center; font-size: 0.9rem; }
      .nav {
  display: flex;
  gap: 1rem;
  align-items: center;
  flex-wrap: wrap;
}

.dropdown {
  position: relative;
  display: inline-block;
}

.dropbtn {
  background: transparent;
  border: 0;
  color: white;
  font: inherit;
  cursor: pointer;
  padding: 0;
}

.dropdown-content {
  display: none;
  position: absolute;
  top: 1.7rem;
  left: 0;
  background: white;
  min-width: 240px;
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(0,0,0,.25);
  z-index: 1000;
}

.dropdown-content a {
  display: block;
  padding: 0.75rem 1rem;
  color: #111827;
  text-decoration: none;
}

.dropdown-content a:hover {
  background: #f3f4f6;
}

.dropdown.open .dropdown-content { display: block; }

    </style>
  </head>
  <body>
    <header>
      <h1>Schützengesellschaft Neustadt</h1>
<nav class="nav">
  <a href="/">Start</a>
  <a href="/termine/">Termine</a>
  <a href="/news/">News</a>

<div class="dropdown" data-dropdown>
  <button class="dropbtn" type="button" aria-haspopup="true" aria-expanded="false">
    Verein ▾
  </button>
  <div class="dropdown-content" role="menu">
    <a href="/vorstand/">Vorstand</a>
    <a href="/vereinsgeschichte/">Vereinsgeschichte</a>
    <a href="/vereinsbeitraege/">Vereinsbeiträge</a>
    <a href="/gesetz-aenderung-waffenaufbewahrung/">Gesetzänderung Waffenaufbewahrung</a>
  </div>
</div>

  <a href="/oeffnungszeiten/">Öffnungszeiten</a>
  <a href="/kontakt/">Kontakt</a>
  <a href="/galerie/">Galerie</a>
  <a href="/downloads/">Downloads</a>
</nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      © {new Date().getFullYear()} SG Neustadt |
      <a href="/impressum/">Impressum</a> |
      <a href="/datenschutz/">Datenschutz</a>
    </footer>
<script>
  document.addEventListener("click", (e) => {
    const dropdowns = document.querySelectorAll("[data-dropdown]");
    dropdowns.forEach((dd) => {
      const btn = dd.querySelector("button");
      const isClickInside = dd.contains(e.target);

      if (isClickInside) {
        dd.classList.toggle("open");
        btn?.setAttribute("aria-expanded", dd.classList.contains("open") ? "true" : "false");
      } else {
        dd.classList.remove("open");
        btn?.setAttribute("aria-expanded", "false");
      }
    });
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      document.querySelectorAll("[data-dropdown]").forEach((dd) => {
        dd.classList.remove("open");
        const btn = dd.querySelector("button");
        btn?.setAttribute("aria-expanded", "false");
      });
    }
  });
</script>
  </body>
</html>
