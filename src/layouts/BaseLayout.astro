---
import "../styles/global.css";

const {
  title = "SG Neustadt",
  description = "Schützenverein SG Neustadt – Informationen zu Training, Veranstaltungen und Vereinsleben.",
  jsonLd = null,
} = Astro.props;

const origin = Astro.url.origin;
const canonical = `${origin}${Astro.url.pathname}`;
const ogImage = `${origin}/og-image.jpg`;

const ORG_NAME = "Schützenverein SG Neustadt";
const ORG_LOGO = `${origin}/favicon.svg`;

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "SportsOrganization",
  name: ORG_NAME,
  url: origin,
  logo: ORG_LOGO,
};

const extraJsonLd = Array.isArray(jsonLd) ? jsonLd : (jsonLd ? [jsonLd] : []);
const mergedJsonLd = [orgJsonLd, ...extraJsonLd];
const jsonLdString = JSON.stringify(mergedJsonLd);
---

<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Favicons -->
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Theme / UI -->
  <meta name="theme-color" content="#2f6c47" />
  <meta name="color-scheme" content="light" />

  <!-- Robots (Default: index,follow – kann bei Bedarf pro Seite überschrieben werden) -->
  <meta name="robots" content="index,follow,max-image-preview:large" />

  <!-- OpenGraph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="SG Neustadt" />
  <meta property="og:locale" content="de_DE" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:secure_url" content={ogImage} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- JSON-LD -->
  {mergedJsonLd.length > 0 && (
    <script type="application/ld+json" set:html={jsonLdString} />
  )}
</head>

  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="/">
<img
  src="/logo.png"
  alt="Schützengesellschaft Neustadt"
  class="brand-logo"
/>
          <span>
            SG Neustadt
            <small>seit 1485 e.V.</small>
          </span>
        </a>

<nav class="nav" aria-label="Hauptnavigation">
  <button
    class="nav-toggle"
    type="button"
    aria-controls="nav-links"
    aria-expanded="false"
  >
    <span class="sr-only">Menü öffnen</span>
    ☰
  </button>

  <div class="nav-links" id="nav-links">
    <a href="/" class={Astro.url.pathname === "/" ? "active" : ""}>Start</a>
    <a href="/news/" class={Astro.url.pathname.startsWith("/news") ? "active" : ""}>News</a>
    <a href="/termine/" class={Astro.url.pathname.startsWith("/termine") ? "active" : ""}>Termine</a>
    <a href="/kontakt/" class={Astro.url.pathname.startsWith("/kontakt") ? "active" : "">Kontakt</a>
    <a href="/downloads/" class={Astro.url.pathname.startsWith("/downloads") ? "active" : ""}>Downloads</a>

    <div class="dropdown" id="verein-dd">
      <button
        type="button"
        class="dropbtn"
        aria-haspopup="true"
        aria-controls="verein-menu"
        aria-expanded="false"
      >
        Verein <span aria-hidden="true">▾</span>
      </button>

      <div class="menu" id="verein-menu" role="menu">
        <a href="/vorstand/" role="menuitem">Der Vorstand</a>
        <a href="/vereinsgeschichte/" role="menuitem">Vereinsgeschichte</a>
        <a href="/oeffnungszeiten/" role="menuitem">Öffnungszeiten</a>
        <a href="/vereinsbeitraege/" role="menuitem">Vereinsbeiträge</a>
        <a href="/gesetz-aenderung-waffenaufbewahrung/" role="menuitem">Gesetzänderung Waffenaufbewahrung</a>
        <a href="/galerie/" role="menuitem">Galerie</a>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  // Mobile menu toggle
  const toggle = document.querySelector(".nav-toggle");
  const links = document.getElementById("nav-links");

  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", open ? "false" : "true");
    links?.classList.toggle("open", !open);
  });

  // Dropdown robust
  const dd = document.getElementById("verein-dd");
  const btn = dd?.querySelector(".dropbtn");

  function closeDropdown() {
    dd?.setAttribute("data-open", "false");
    btn?.setAttribute("aria-expanded", "false");
  }
  function toggleDropdown() {
    const open = dd?.getAttribute("data-open") === "true";
    dd?.setAttribute("data-open", open ? "false" : "true");
    btn?.setAttribute("aria-expanded", open ? "false" : "true");
  }

  btn?.addEventListener("click", (e) => {
    e.preventDefault();
    e.stopPropagation();
    toggleDropdown();
  });

  document.addEventListener("click", (e) => {
    if (!dd) return;
    if (!dd.contains(e.target)) closeDropdown();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeDropdown();
  });
</script>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div style="font-weight:800;">© {new Date().getFullYear()} SG Neustadt</div>
        <div class="footer-links">
          <a href="/impressum/">Impressum</a>
          <a href="/datenschutz/">Datenschutz</a>
          <a href="/kontakt/">Kontakt</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Dropdown: bleibt offen bis Klick außerhalb / ESC
      const dd = document.getElementById("verein-dd");
      const btn = dd?.querySelector("button");

      function close() {
        dd?.setAttribute("aria-expanded", "false");
      }
      function toggle() {
        const open = dd?.getAttribute("aria-expanded") === "true";
        dd?.setAttribute("aria-expanded", open ? "false" : "true");
      }

      btn?.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        toggle();
      });

      document.addEventListener("click", (e) => {
        if (!dd) return;
        if (!dd.contains(e.target)) close();
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") close();
      });
    </script>
  </body>
</html>
